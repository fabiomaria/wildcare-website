---
pageSlug: "programm"
useTally: true
eleventyComputed:
  title: "{{ i18n[locale].programm.meta.title }}"
  description: "{{ i18n[locale].programm.meta.description }}"
---

<!-- ================================
     HERO
     ================================ -->

<header class="page-hero">
    <div class="container">
        <p class="label fade-up">{{ i18n[locale].programm.hero.eyebrow }}</p>
        <h1 class="fade-up delay-1">{{ i18n[locale].programm.hero.heading }}</h1>
        <p class="fade-up delay-2">{{ i18n[locale].programm.hero.intro }}</p>
    </div>
</header>

<!-- ================================
     MONTAGSKURS
     ================================ -->

<section class="montagskurs">
    <div class="container">
        <div class="section-header fade-up" style="margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].programm.montagskurs.section_label }}</p>
            <h2>{{ i18n[locale].programm.montagskurs.section_heading }}</h2>
        </div>

        <div class="montagskurs-layout">
            <div class="info-card fade-up delay-1">
                <div class="info-card-title">{{ i18n[locale].programm.montagskurs.card_title }}</div>

                <div class="info-row">
                    <div class="info-row-icon">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    </div>
                    <div class="info-row-content">
                        <div class="info-row-label">{{ i18n[locale].programm.montagskurs.row_was_label }}</div>
                        <div class="info-row-value">{{ i18n[locale].programm.montagskurs.row_was_value }}</div>
                    </div>
                </div>

                <div class="info-row">
                    <div class="info-row-icon">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    </div>
                    <div class="info-row-content">
                        <div class="info-row-label">{{ i18n[locale].programm.montagskurs.row_wann_label }}</div>
                        <div class="info-row-value">{{ i18n[locale].programm.montagskurs.row_wann_value }}</div>
                    </div>
                </div>

                <div class="info-row">
                    <div class="info-row-icon">
                        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div class="info-row-content">
                        <div class="info-row-label">{{ i18n[locale].programm.montagskurs.row_wo_label }}</div>
                        <div class="info-row-value">Orpheumgasse 11, 8020 Graz</div>
                    </div>
                </div>

                <div class="info-row">
                    <div class="info-row-icon">
                        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M12 6v2M12 16v2"/></svg>
                    </div>
                    <div class="info-row-content">
                        <div class="info-row-label">{{ i18n[locale].programm.montagskurs.row_kosten_label }}</div>
                        <div class="info-row-value">{{ i18n[locale].programm.montagskurs.row_kosten_value }}</div>
                    </div>
                </div>

                <div class="info-row">
                    <div class="info-row-icon">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                    </div>
                    <div class="info-row-content">
                        <div class="info-row-label">{{ i18n[locale].programm.montagskurs.row_fuer_label }}</div>
                        <div class="info-row-value">{{ i18n[locale].programm.montagskurs.row_fuer_value }}</div>
                    </div>
                </div>

                <div class="info-card-cta" style="display: flex; gap: var(--space-sm);">
                    <button class="btn btn-primary" style="flex: 1; justify-content: center;" data-tally-open="nplWX8" data-tally-emoji-text="👋" data-tally-emoji-animation="wave">{{ i18n[locale].programm.montagskurs.btn_anmelden }}</button>
                    <a href="/{{ 'en/' if locale == 'en' }}montagskurs.html" class="btn btn-secondary" style="flex: 1; justify-content: center;">{{ i18n[locale].programm.montagskurs.btn_mehr }}</a>
                </div>
            </div>

            <div class="montagskurs-description fade-up delay-2">
                <h2>{{ i18n[locale].programm.montagskurs.desc_heading }}</h2>
                <p>{{ i18n[locale].programm.montagskurs.desc_p1 }}</p>
                <p>{{ i18n[locale].programm.montagskurs.desc_p2 }}</p>
                <p>{{ i18n[locale].programm.montagskurs.desc_p3 }}</p>
                <p class="quote">{{ i18n[locale].programm.montagskurs.desc_quote }}</p>
            </div>
        </div>
    </div>
</section>

<!-- ================================
     AKTUELLE PROJEKTE
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="margin-bottom: 48px;">
            <p class="label">{{ i18n[locale].programm.projekte.section_label }}</p>
            <h2>{{ i18n[locale].programm.projekte.section_heading }}</h2>
        </div>

        <div class="projekt-card fade-up delay-1">
            <div class="projekt-card-accent"></div>
            <div class="projekt-card-body">
                <div class="projekt-card-meta">
                    <span class="projekt-tag">{{ i18n[locale].programm.projekte.br_tag1 }}</span>
                    <span class="projekt-tag projekt-tag-moss">{{ i18n[locale].programm.projekte.br_tag2 }}</span>
                </div>
                <h3>{{ i18n[locale].programm.projekte.br_heading }}</h3>
                <div class="projekt-card-subtitle">{{ i18n[locale].programm.projekte.br_subtitle }}</div>
                <p>{{ i18n[locale].programm.projekte.br_p1 }}</p>
                <p>{{ i18n[locale].programm.projekte.br_p2 }}</p>

                <div class="projekt-details">
                    <div class="projekt-detail">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        <span>{{ i18n[locale].programm.projekte.br_detail_date }}</span>
                    </div>
                    <div class="projekt-detail">
                        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        Orpheumgasse 11, Graz
                    </div>
                    <div class="projekt-detail">
                        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M12 6v2M12 16v2"/></svg>
                        <span>{{ i18n[locale].programm.projekte.br_detail_cost }}</span>
                    </div>
                    <div class="projekt-detail">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                        <span>{{ i18n[locale].programm.projekte.br_detail_weeks }}</span>
                    </div>
                </div>

                <div style="margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: var(--border-subtle); display: flex; gap: var(--space-sm); flex-wrap: wrap;">
                    <button class="btn btn-primary" data-tally-open="eq227x" data-tally-emoji-text="👋" data-tally-emoji-animation="wave">{{ i18n[locale].programm.projekte.br_btn_anmelden }}</button>
                    <a href="/{{ 'en/' if locale == 'en' }}bewegungsrevolution.html" class="btn btn-secondary">{{ i18n[locale].programm.projekte.br_btn_mehr }}</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================================
     AUSBLICK
     ================================ -->

<section style="background: var(--sand-light);">
    <div class="container">
        <div class="section-header fade-up" style="margin-bottom: 48px;">
            <p class="label">{{ i18n[locale].programm.ausblick.section_label }}</p>
            <h2>{{ i18n[locale].programm.ausblick.section_heading }}</h2>
            <p>{{ i18n[locale].programm.ausblick.section_intro }}</p>
        </div>

        <div class="ausblick-grid">
            <div class="preview-card fade-up delay-1">
                <div class="preview-card-label">{{ i18n[locale].programm.ausblick.wjm_label }}</div>
                <h3>{{ i18n[locale].programm.ausblick.wjm_heading }}</h3>
                <div class="preview-card-subtitle">{{ i18n[locale].programm.ausblick.wjm_subtitle }}</div>
                <p>{{ i18n[locale].programm.ausblick.wjm_p1 }}</p>
                <p>{{ i18n[locale].programm.ausblick.wjm_p2 }}</p>
            </div>

            <div class="preview-card fade-up delay-2">
                <div class="preview-card-label">{{ i18n[locale].programm.ausblick.bip_label }}</div>
                <h3>{{ i18n[locale].programm.ausblick.bip_heading }}</h3>
                <div class="preview-card-subtitle">{{ i18n[locale].programm.ausblick.bip_subtitle }}</div>
                <p>{{ i18n[locale].programm.ausblick.bip_p1 }}</p>
                <a href="https://bewegt-im-park.at" target="_blank" rel="noopener" class="btn btn-ghost">{{ i18n[locale].programm.ausblick.bip_btn }}</a>
            </div>
        </div>
    </div>
</section>

<!-- ================================
     CTA
     ================================ -->

<section class="cta-section">
    <div class="container fade-up">
        <p class="label" style="color: var(--warmwhite); opacity: 0.5; margin-bottom: 16px;">{{ i18n[locale].programm.cta.label }}</p>
        <h2>{{ i18n[locale].programm.cta.heading }}</h2>
        <p>{{ i18n[locale].programm.cta.text }}</p>
        <a href="/{{ 'en/' if locale == 'en' }}kontakt.html" class="btn btn-primary">{{ i18n[locale].programm.cta.button }}</a>
    </div>
</section>
