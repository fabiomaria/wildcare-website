---
pageSlug: "bewegungsrevolution"
useTally: true
eleventyComputed:
  title: "{{ i18n[locale].bewegungsrevolution.meta.title }}"
  description: "{{ i18n[locale].bewegungsrevolution.meta.description }}"
---

<!-- ================================
     HERO + VIDEO
     ================================ -->

<header class="detail-hero">
    <div class="container">
        <div class="detail-hero-grid">

            <div class="detail-hero-content accent-terracotta fade-up">
                <div class="detail-badge">{{ i18n[locale].bewegungsrevolution.hero.badge }}</div>

                <h1>{{ i18n[locale].bewegungsrevolution.hero.heading | safe }}</h1>

                <p class="detail-hero-subtitle">{{ i18n[locale].bewegungsrevolution.hero.subtitle }}</p>

                <div class="detail-hero-details">
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        <span>{{ i18n[locale].bewegungsrevolution.hero.detail_dates }}</span>
                    </div>
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        <span>{{ i18n[locale].bewegungsrevolution.hero.detail_time }}</span>
                    </div>
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {{ i18n[locale].bewegungsrevolution.hero.detail_location }}
                    </div>
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M12 6v2M12 16v2"/></svg>
                        <span>{{ i18n[locale].bewegungsrevolution.hero.detail_price }}</span>
                    </div>
                </div>

                <div class="detail-hero-cta">
                    <button class="btn btn-primary" data-tally-open="eq227x" data-tally-emoji-text="👋" data-tally-emoji-animation="wave">{{ i18n[locale].bewegungsrevolution.hero.cta_btn }}</button>
                    <p class="detail-hero-note">{{ i18n[locale].bewegungsrevolution.hero.note }}</p>
                </div>
            </div>

            <div class="detail-video-wrapper fade-up delay-2">
                <video autoplay muted loop playsinline preload="metadata" poster="/assets/images/bewegungsrevolution.png">
                    <source src="/assets/what is ci.mp4" type="video/mp4">
                </video>
            </div>

        </div>
    </div>
</header>

<!-- ================================
     6-WOCHEN-FAHRPLAN
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].bewegungsrevolution.schedule.label }}</p>
            <h2>{{ i18n[locale].bewegungsrevolution.schedule.heading }}</h2>
        </div>

        <div class="detail-card-grid">
            {% for week in i18n[locale].bewegungsrevolution.schedule.weeks %}
            <div class="detail-card{% if week.highlighted %} highlighted{% endif %} fade-up delay-{{ loop.index }}">
                <p class="detail-card-number">{{ week.number }}</p>
                <h3>{{ week.title }}</h3>
                <p>{{ week.body }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     ZITAT
     ================================ -->

<section class="detail-quote-section">
    <div class="container fade-up" style="text-align: center; max-width: 800px;">
        <div class="divider" style="margin: 0 auto var(--space-xl);"></div>
        <p class="quote">{{ i18n[locale].bewegungsrevolution.quote.text }}</p>
        <div class="divider" style="margin: var(--space-xl) auto 0;"></div>
    </div>
</section>

<!-- ================================
     TESTIMONIALS
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].bewegungsrevolution.testimonials.label }}</p>
            <h2>{{ i18n[locale].bewegungsrevolution.testimonials.heading }}</h2>
        </div>

        <div class="detail-testimonial-grid">
            {% for item in i18n[locale].bewegungsrevolution.testimonials.items %}
            <div class="detail-testimonial fade-up delay-{{ loop.index }}">
                <blockquote>{{ item.quote }}</blockquote>
                <p class="detail-testimonial-author">{{ item.author }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     TEAM
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].bewegungsrevolution.team.label }}</p>
            <h2>{{ i18n[locale].bewegungsrevolution.team.heading }}</h2>
        </div>

        <div class="detail-team-grid">
            {% for member in i18n[locale].bewegungsrevolution.team.members %}
            <div class="detail-team-member fade-up delay-{{ loop.index }}">
                <div class="detail-team-portrait">
                    <img src="{{ member.photo }}" alt="{{ member.name }}" loading="lazy">
                </div>
                <div class="detail-team-info">
                    <h3>{{ member.name }}</h3>
                    <p class="detail-team-role">{{ member.role }}</p>
                    <p>{{ member.bio }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     FAQ
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 48px;">
            <p class="label">{{ i18n[locale].bewegungsrevolution.faq.label }}</p>
            <h2>{{ i18n[locale].bewegungsrevolution.faq.heading }}</h2>
        </div>

        <div class="detail-faq-list">
            {% for item in i18n[locale].bewegungsrevolution.faq.items %}
            <div class="detail-faq-item fade-up">
                <p class="detail-faq-q">{{ item.q }}</p>
                <p class="detail-faq-a">{{ item.a }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     CTA
     ================================ -->

<section class="cta-section">
    <div class="container fade-up">
        <p class="label" style="color: var(--warmwhite); opacity: 0.5; margin-bottom: 16px;">{{ i18n[locale].bewegungsrevolution.cta.label }}</p>
        <h2>{{ i18n[locale].bewegungsrevolution.cta.heading }}</h2>
        <p>{{ i18n[locale].bewegungsrevolution.cta.text }}</p>
        <button class="btn btn-primary" data-tally-open="eq227x" data-tally-emoji-text="👋" data-tally-emoji-animation="wave" style="background: var(--warmwhite); color: var(--moss);">{{ i18n[locale].bewegungsrevolution.cta.btn }}</button>
    </div>
</section>
