---
pageSlug: "montagskurs"
useTally: true
eleventyComputed:
  title: "{{ i18n[locale].montagskurs.meta.title }}"
  description: "{{ i18n[locale].montagskurs.meta.description }}"
---

<!-- ================================
     HERO
     ================================ -->

<header class="detail-hero">
    <div class="container">
        <div class="detail-hero-grid">

            <div class="detail-hero-content fade-up">
                <p class="label">{{ i18n[locale].montagskurs.hero.eyebrow }}</p>
                <h1>{{ i18n[locale].montagskurs.hero.heading | safe }}</h1>
                <p class="detail-hero-subtitle">{{ i18n[locale].montagskurs.hero.subtitle }}</p>

                <div class="detail-hero-details">
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        <span>{{ i18n[locale].montagskurs.hero.detail_time }}</span>
                    </div>
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {{ i18n[locale].montagskurs.hero.detail_location }}
                    </div>
                    <div class="detail-hero-detail">
                        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M12 6v2M12 16v2"/></svg>
                        <span>{{ i18n[locale].montagskurs.hero.detail_price }}</span>
                    </div>
                </div>

                <div class="detail-hero-cta">
                    <button class="btn btn-primary" data-tally-open="nplWX8" data-tally-emoji-text="👋" data-tally-emoji-animation="wave">{{ i18n[locale].montagskurs.hero.cta_btn }}</button>
                    <p class="detail-hero-note">{{ i18n[locale].montagskurs.hero.note }}</p>
                </div>
            </div>

            <div class="detail-photo fade-up delay-2">
                <img src="/assets/images/warum-ci.jpg" alt="Contact Improvisation">
            </div>

        </div>
    </div>
</header>

<!-- ================================
     WAS IST CONTACT IMPROVISATION
     ================================ -->

<section class="detail-about">
    <div class="container">
        <div class="detail-about-grid">
            <div class="detail-about-text fade-up">
                <p class="label">{{ i18n[locale].montagskurs.about.label }}</p>
                <h2>{{ i18n[locale].montagskurs.about.heading }}</h2>
                <p>{{ i18n[locale].montagskurs.about.p1 }}</p>
                <p>{{ i18n[locale].montagskurs.about.p2 }}</p>
            </div>
            <div class="detail-video-wrapper fade-up delay-2">
                <video autoplay muted loop playsinline preload="metadata" poster="/assets/images/warum-ci.jpg">
                    <source src="/assets/what is ci.mp4" type="video/mp4">
                </video>
            </div>
        </div>
    </div>
</section>

<!-- ================================
     WAS DU LERNST
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].montagskurs.learn.label }}</p>
            <h2>{{ i18n[locale].montagskurs.learn.heading }}</h2>
        </div>

        <div class="detail-card-grid">
            {% for card in i18n[locale].montagskurs.learn.cards %}
            <div class="detail-card fade-up delay-{{ loop.index }}">
                <h3>{{ card.title }}</h3>
                <p>{{ card.body }}</p>
            </div>
            {% endfor %}
        </div>

        <div class="detail-donation-note fade-up">
            <p>{{ i18n[locale].montagskurs.learn.donation_note }}</p>
        </div>
    </div>
</section>

<!-- ================================
     TESTIMONIALS
     ================================ -->

<section class="detail-testimonials">
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].montagskurs.testimonials.label }}</p>
            <h2>{{ i18n[locale].montagskurs.testimonials.heading }}</h2>
        </div>

        <div class="detail-testimonial-grid">
            {% for item in i18n[locale].montagskurs.testimonials.items %}
            <div class="detail-testimonial fade-up delay-{{ loop.index }}">
                <blockquote>{{ item.quote }}</blockquote>
                <p class="detail-testimonial-author">{{ item.author }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     TEAM
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 56px;">
            <p class="label">{{ i18n[locale].montagskurs.team.label }}</p>
            <h2>{{ i18n[locale].montagskurs.team.heading }}</h2>
        </div>

        <div class="detail-team-grid">
            {% for member in i18n[locale].montagskurs.team.members %}
            <div class="detail-team-member fade-up delay-{{ loop.index }}">
                <div class="detail-team-portrait">
                    <img src="{{ member.photo }}" alt="{{ member.name }}" loading="lazy">
                </div>
                <div class="detail-team-info">
                    <h3>{{ member.name }}</h3>
                    <p class="detail-team-role">{{ member.role }}</p>
                    <p>{{ member.bio }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     FAQ
     ================================ -->

<section style="background: var(--sand-light);">
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 48px;">
            <p class="label">{{ i18n[locale].montagskurs.faq.label }}</p>
            <h2>{{ i18n[locale].montagskurs.faq.heading }}</h2>
        </div>

        <div class="detail-faq-list">
            {% for item in i18n[locale].montagskurs.faq.items %}
            <div class="detail-faq-item fade-up">
                <p class="detail-faq-q">{{ item.q }}</p>
                <p class="detail-faq-a">{{ item.a }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     BEWEGUNGSREVOLUTION CROSS-LINK
     ================================ -->

<section style="background: var(--sand-light);">
    <div class="container fade-up" style="text-align: center; max-width: 700px;">
        <p class="label">{{ i18n[locale].montagskurs.crosslink.label }}</p>
        <h2>{{ i18n[locale].montagskurs.crosslink.heading }}</h2>
        <p style="font-size: 1.0625rem; opacity: 0.7; line-height: 1.75; margin: 0 auto var(--space-xl);">{{ i18n[locale].montagskurs.crosslink.text }}</p>
        <a href="/{{ 'en/' if locale == 'en' }}bewegungsrevolution.html" class="btn btn-primary">{{ i18n[locale].montagskurs.crosslink.btn }}</a>
    </div>
</section>

<!-- ================================
     CTA
     ================================ -->

<section class="cta-section">
    <div class="container fade-up">
        <p class="label" style="color: var(--warmwhite); opacity: 0.5; margin-bottom: 16px;">{{ i18n[locale].montagskurs.cta.label }}</p>
        <h2>{{ i18n[locale].montagskurs.cta.heading }}</h2>
        <p>{{ i18n[locale].montagskurs.cta.text }}</p>
        <button class="btn btn-primary" data-tally-open="nplWX8" data-tally-emoji-text="👋" data-tally-emoji-animation="wave" style="background: var(--warmwhite); color: var(--moss);">{{ i18n[locale].montagskurs.cta.btn }}</button>
    </div>
</section>
