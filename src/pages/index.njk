---
pageSlug: "index"
bodyClass: "has-hero-video"
useTally: true
eleventyComputed:
  title: "{{ i18n[locale].home.meta.title }}"
  description: "{{ i18n[locale].home.meta.description }}"
---

<!-- ================================
     VIDEO HERO
     ================================ -->

<header class="hero-video">
    <video autoplay muted loop playsinline preload="metadata" poster="/assets/images/hero-poster.jpg">
        <source src="/assets/video-hero.mp4" type="video/mp4">
    </video>
    <div class="hero-video-overlay"></div>

    <div class="hero-video-content">
        <div class="container">
            <h1 class="fade-up">{{ i18n[locale].home.hero.heading | safe }}</h1>
            <p class="fade-up delay-1">{{ i18n[locale].home.hero.subtitle }}</p>
            <div class="button-row fade-up delay-2">
                <button class="btn btn-primary" data-tally-open="nplWX8" data-tally-emoji-text="👋" data-tally-emoji-animation="wave">{{ i18n[locale].home.hero.btn_primary }}</button>
                <a href="/{{ 'en/' if locale == 'en' }}programm.html" class="btn btn-secondary">{{ i18n[locale].home.hero.btn_secondary }}</a>
            </div>
        </div>
    </div>

    <div class="hero-scroll-hint">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
</header>

<!-- ================================
     NEXT EVENT BANNER
     ================================ -->

<div class="event-banner">
    <div class="container event-banner-inner">
        <div class="event-banner-info">
            <span class="event-banner-tag">{{ i18n[locale].home.event_banner.tag }}</span>
            <div class="event-banner-detail">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                <span>{{ i18n[locale].home.event_banner.day }}</span>
            </div>
            <div class="event-banner-detail">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                17:45 – 19:15
            </div>
            <div class="event-banner-detail">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Orpheumgasse 11, Graz
            </div>
            <div class="event-banner-detail">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z"/><path d="M12 6v2M12 16v2"/></svg>
                <span>{{ i18n[locale].home.event_banner.donation }}</span>
            </div>
        </div>
    </div>
</div>

<!-- ================================
     CORE VALUES
     ================================ -->

<section id="werte">
    <div class="container">
        <div class="section-header fade-up" style="text-align: center; margin-bottom: 64px;">
            <p class="label">{{ i18n[locale].home.values.eyebrow }}</p>
            <h2>{{ i18n[locale].home.values.heading }}</h2>
        </div>

        <div class="values-grid">
            {% set delays = ["delay-1", "delay-2", "delay-3", "delay-4"] %}
            {% for value in i18n[locale].home.values.items %}
            <div class="value-card fade-up {{ delays[loop.index0] }}">
                <div class="value-icon">
                    {{ value.icon | safe }}
                </div>
                <h3>{{ value.heading }}</h3>
                <p>{{ value.text }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ================================
     INVITATION
     ================================ -->

<section class="invitation">
    <div class="container">
        <div class="invitation-grid">
            <div class="invitation-text fade-up">
                <p class="label" style="margin-bottom: 12px;">{{ i18n[locale].home.invitation.eyebrow }}</p>
                <h2>{{ i18n[locale].home.invitation.heading }}</h2>
                <p>{{ i18n[locale].home.invitation.p1 }}</p>
                <p>{{ i18n[locale].home.invitation.p2 }}</p>
                <div class="button-row" style="margin-top: 8px;">
                    <a href="/{{ 'en/' if locale == 'en' }}montagskurs.html" class="btn btn-ghost">{{ i18n[locale].home.invitation.btn }}</a>
                </div>
            </div>
            <div class="invitation-image fade-up delay-2">
                <div class="invitation-image-frame">
                    <img src="/assets/images/invitation.jpg" alt="Contact Improvisation Session" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div class="invitation-image-accent"></div>
            </div>
        </div>
    </div>
</section>

<!-- ================================
     MANIFEST QUOTE
     ================================ -->

<section style="background: var(--sand-light);">
    <div class="container fade-up" style="text-align: center; max-width: 800px;">
        <div class="divider" style="margin: 0 auto var(--space-xl);"></div>
        <p class="quote">{{ i18n[locale].home.quote }}</p>
        <div class="divider" style="margin: var(--space-xl) auto 0;"></div>
    </div>
</section>

<!-- ================================
     JOURNAL TEASER
     ================================ -->

<section>
    <div class="container">
        <div class="section-header fade-up" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px;">
            <div>
                <p class="label">{{ i18n[locale].home.journal.label }}</p>
                <h2>{{ i18n[locale].home.journal.heading }}</h2>
            </div>
            <a href="/{{ 'en/' if locale == 'en' }}journal.html" class="btn btn-ghost">{{ i18n[locale].home.journal.all_posts }}</a>
        </div>

        <div class="journal-grid">
            {% for card in i18n[locale].home.journal.cards %}
            <a href="{{ card.url }}" class="journal-card compact fade-up {{ ['delay-1', 'delay-2'][loop.index0] }}">
                <div class="journal-card-image">
                    <img src="{{ card.image }}" alt="{{ card.image_alt }}" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div class="journal-card-body">
                    <p class="journal-card-date">{{ card.date }}</p>
                    <h3>{{ card.heading }}</h3>
                    <p>{{ card.excerpt }}</p>
                </div>
            </a>
            {% endfor %}

            {# Static "coming soon" card #}
            {% set cs = i18n[locale].home.journal.coming_soon %}
            <a href="#" class="journal-card compact coming-soon fade-up delay-3">
                <div class="journal-card-image">
                    <img src="{{ cs.image }}" alt="{{ cs.image_alt }}" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div class="journal-card-body">
                    <p class="journal-card-date">{{ cs.date }}</p>
                    <h3>{{ cs.heading }}</h3>
                    <p>{{ cs.excerpt }}</p>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ================================
     CTA
     ================================ -->

<section class="cta-section">
    <div class="container fade-up">
        <p class="label" style="color: var(--warmwhite); opacity: 0.5; margin-bottom: 16px;">{{ i18n[locale].home.cta.eyebrow }}</p>
        <h2>{{ i18n[locale].home.cta.heading }}</h2>
        <p>{{ i18n[locale].home.cta.text }}</p>
        <a href="/{{ 'en/' if locale == 'en' }}kontakt.html" class="btn btn-primary">{{ i18n[locale].home.cta.btn }}</a>
    </div>
</section>
